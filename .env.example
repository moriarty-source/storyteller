# ── Datenbank ─────────────────────────────────────────────────────────────────
#
# Vercel (Neon Postgres):
#   Wird automatisch gesetzt wenn du eine Neon-Datenbank im Vercel Dashboard
#   unter Storage verknüpfst. Mögliche Variablennamen (einer reicht):
#
# POSTGRES_URL=postgresql://user:pass@host/db?sslmode=require
# STORAGE_URL=postgresql://user:pass@host/db?sslmode=require
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
#
# Raspberry Pi / Lokal (SQLite):
#   Keine Datenbank-Variable nötig. SQLite-Datei liegt unter data/stories.db.
#   Optional: anderer Pfad
#
# DB_PATH=/home/pi/storyteller/data/stories.db

# ── Hinweise ──────────────────────────────────────────────────────────────────
#
# Das Admin-Passwort wird NICHT als Env-Variable gesetzt, sondern liegt in
# der Datenbank (Tabelle config, Key 'adminPassword').
# Standard-Passwort nach Erststart: "admin"
# Änderbar im Admin-Board unter Einstellungen.
